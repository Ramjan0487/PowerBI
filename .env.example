# Contract Management System — Environment Variables
SECRET_KEY=change-this-long-random-string
FLASK_ENV=production
DB_PASSWORD=strong-db-password
DATABASE_URL=postgresql://cms:${DB_PASSWORD}@postgres:5432/cms
REDIS_URL=redis://redis:6379/0
# SMTP
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=contracts@company.com
MAIL_PASSWORD=your-mail-password
# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
# AI
OPENAI_API_KEY=sk-...
# API key for PowerBI + external access
CMS_API_KEY=generate-a-strong-random-key
# PowerBI
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=
# PKI
MTLS_CA_CERT=certs/ca/ca.crt
MTLS_SERVER_CERT=certs/server/server.crt
MTLS_SERVER_KEY=certs/server/server.key
VERIFY_CLIENT_CERT=true
# Grafana
GRAFANA_PASSWORD=admin
# Katalon
KATALON_API_KEY=
